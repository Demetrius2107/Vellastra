    },
    "/menu/{id}": {
      "get": {
        "tags": ["菜单管理"],
        "summary": "获取菜单详情",
        "description": "根据ID获取菜单详细信息",
        "operationId": "getMenuById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回菜单详情",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": { "id": 1, "menuName": "系统管理", "menuType": 1, "parentId": null, "path": "/system", "component": null, "perms": null, "icon": "setting", "sortOrder": 1, "visible": 1, "status": 1, "createTime": "2026-07-18T10:00:00" }
                }
              }
            }
          }
        }
      }
    },
    "/menu": {
      "post": {
        "tags": ["菜单管理"],
        "summary": "创建菜单",
        "description": "创建新菜单（目录/菜单/按钮）",
        "operationId": "createMenu",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateMenuRequest" },
              "example": { "menuName": "评论管理", "menuType": 2, "parentId": 7, "path": "/content/comment", "component": "content/comment/index", "perms": "", "icon": "message", "sortOrder": 3 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功，返回新菜单ID",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": 11 }
              }
            }
          }
        }
      }
    },
    "/menu/{id}": {
      "put": {
        "tags": ["菜单管理"],
        "summary": "更新菜单",
        "description": "更新菜单信息",
        "operationId": "updateMenu",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 11
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateMenuRequest" },
              "example": { "menuName": "评论管理", "menuType": 2, "path": "/content/comment", "component": "content/comment/index", "perms": "comment:list", "icon": "message", "sortOrder": 3, "visible": 1, "status": 1 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["菜单管理"],
        "summary": "删除菜单",
        "description": "删除菜单（有子菜单时不允许删除）",
        "operationId": "deleteMenu",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 11
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          },
          "400": {
            "description": "存在子菜单无法删除",
            "content": {
              "application/json": {
                "example": { "code": 400, "message": "该菜单下存在子菜单，无法删除", "data": null }
              }
            }
          }
        }
      }
    },
    "/user/{userId}/roles": {
      "get": {
        "tags": ["用户-角色管理"],
        "summary": "获取用户角色ID列表",
        "description": "查询指定用户所分配的角色ID列表",
        "operationId": "getUserRoleIds",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回角色ID列表",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": [1, 2] }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["用户-角色管理"],
        "summary": "分配用户角色",
        "description": "全量覆盖用户的角色分配",
        "operationId": "assignRoles",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 1
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": [1, 2]
            }
          }
        },
        "responses": {
          "200": {
            "description": "分配成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string", "description": "用户名", "example": "admin" },
          "password": { "type": "string", "description": "明文密码", "example": "admin123" }
        },
        "required": ["username", "password"]
      },
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "username": { "type": "string", "description": "用户名", "example": "newuser" },
          "password": { "type": "string", "description": "明文密码", "example": "password123" },
          "email": { "type": "string", "description": "邮箱", "example": "newuser@example.com" }
        },
        "required": ["username", "password", "email"]
      },
      "TokenVO": {
        "type": "object",
