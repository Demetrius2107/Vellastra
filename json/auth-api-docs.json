{
  "openapi": "3.0.1",
  "info": {
    "title": "Vellastra Auth API - Phase 1",
    "description": "认证鉴权核心接口，包括登录/注册/登出/Token刷新、角色管理、菜单权限管理、用户-角色分配",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "API Gateway"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户登录",
        "description": "使用用户名和密码登录，返回 JWT Token",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "admin",
                "password": "admin123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultTokenVO"
                },
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGVzIjoiMSIsImlhdCI6MTc1MDAwMDAwMCwiZXhwIjoxNzUwMDA3MjAwfQ.example-signature",
                    "expireIn": 7200
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "example": {
                  "code": 400,
                  "message": "用户名不能为空",
                  "data": null
                }
              }
            }
          },
          "401": {
            "description": "登录失败",
            "content": {
              "application/json": {
                "examples": {
                  "userNotFound": {
                    "summary": "用户不存在",
                    "value": { "code": 1001, "message": "用户不存在", "data": null }
                  },
                  "passwordError": {
                    "summary": "密码错误",
                    "value": { "code": 1002, "message": "密码错误", "data": null }
                  },
                  "userDisabled": {
                    "summary": "用户被禁用",
                    "value": { "code": 1003, "message": "用户已被禁用", "data": null }
                  },
                  "userLocked": {
                    "summary": "账号被锁定",
                    "value": { "code": 1006, "message": "账号已被锁定，请15分钟后再试", "data": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户注册",
        "description": "注册新用户，密码需满足强度要求（至少8位，包含字母和数字）",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              },
              "example": {
                "username": "newuser",
                "password": "password123",
                "email": "newuser@example.com"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "注册成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          },
          "400": {
            "description": "参数校验失败",
            "content": {
              "application/json": {
                "examples": {
                  "weakPassword": {
                    "summary": "密码强度不足",
                    "value": { "code": 1005, "message": "密码强度不足，至少8位且包含字母和数字", "data": null }
                  },
                  "duplicateUsername": {
                    "summary": "用户名已存在",
                    "value": { "code": 1004, "message": "用户已存在", "data": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["认证管理"],
        "summary": "用户登出",
        "description": "将当前 Token 加入黑名单，使其失效",
        "operationId": "logout",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "example": "Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGVzIjoiMSJ9.example-signature"
          }
        ],
        "responses": {
          "200": {
            "description": "登出成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["认证管理"],
        "summary": "刷新 Token",
        "description": "使用尚未过期的 Token 换取新 Token",
        "operationId": "refresh",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "required": true,
            "schema": { "type": "string" },
            "example": "Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGVzIjoiMSJ9.example-signature"
          }
        ],
        "responses": {
          "200": {
            "description": "刷新成功，返回新 Token",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiIxIiwidXNlcm5hbWUiOiJhZG1pbiIsInJvbGVzIjoiMSJ9.new-token-signature",
                    "expireIn": 7200
                  }
                }
              }
            }
          },
          "401": {
            "description": "Token 无效或已过期",
            "content": {
              "application/json": {
                "examples": {
                  "tokenInvalid": {
                    "summary": "Token 无效",
                    "value": { "code": 2002, "message": "Token无效", "data": null }
                  },
                  "tokenExpired": {
                    "summary": "Token 已过期",
                    "value": { "code": 2001, "message": "Token已过期", "data": null }
                  },
                  "tokenBlacklisted": {
                    "summary": "Token 已登出",
                    "value": { "code": 2003, "message": "Token已登出，请重新登录", "data": null }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/role/list": {
      "get": {
        "tags": ["角色管理"],
        "summary": "获取角色列表",
        "description": "获取所有角色列表",
        "operationId": "listRoles",
        "responses": {
          "200": {
            "description": "成功返回角色列表",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": [
                    { "id": 1, "roleName": "超级管理员", "roleCode": "SUPER_ADMIN", "description": "系统超级管理员，拥有所有权限", "sortOrder": 1, "status": 1, "createTime": "2026-07-18T10:00:00" },
                    { "id": 2, "roleName": "内容编辑", "roleCode": "EDITOR", "description": "内容编辑，可管理文章和分类", "sortOrder": 2, "status": 1, "createTime": "2026-07-18T10:00:00" },
                    { "id": 3, "roleName": "访客", "roleCode": "GUEST", "description": "普通访客，仅可浏览", "sortOrder": 3, "status": 1, "createTime": "2026-07-18T10:00:00" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/role/{id}": {
      "get": {
        "tags": ["角色管理"],
        "summary": "获取角色详情",
        "description": "根据角色ID获取角色详细信息",
        "operationId": "getRoleById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回角色详情",
            "content": {
              "application/json": {
                "example": {
                  "code": 200,
                  "message": "success",
                  "data": { "id": 1, "roleName": "超级管理员", "roleCode": "SUPER_ADMIN", "description": "系统超级管理员，拥有所有权限", "sortOrder": 1, "status": 1, "createTime": "2026-07-18T10:00:00" }
                }
              }
            }
          },
          "404": {
            "description": "角色不存在",
            "content": {
              "application/json": {
                "example": { "code": 5001, "message": "角色不存在", "data": null }
              }
            }
          }
        }
      },
      "put": {
        "tags": ["角色管理"],
        "summary": "更新角色",
        "description": "更新角色信息",
        "operationId": "updateRole",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 1
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateRoleRequest" },
              "example": { "roleName": "超级管理员", "roleCode": "SUPER_ADMIN", "description": "系统超级管理员", "sortOrder": 1, "status": 1 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          }
        }
      },
      "delete": {
        "tags": ["角色管理"],
        "summary": "删除角色",
        "description": "根据角色ID删除角色",
        "operationId": "deleteRole",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 3
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          }
        }
      }
    },
    "/role": {
      "post": {
        "tags": ["角色管理"],
        "summary": "创建角色",
        "description": "创建新角色",
        "operationId": "createRole",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateRoleRequest" },
              "example": { "roleName": "测试角色", "roleCode": "TEST", "description": "测试用角色", "sortOrder": 4 }
            }
          }
        },
        "responses": {
          "200": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": 4 }
              }
            }
          }
        }
      }
    },
    "/role/{id}/menus": {
      "put": {
        "tags": ["角色管理"],
        "summary": "分配角色菜单权限",
        "description": "全量覆盖角色的菜单权限",
        "operationId": "assignMenus",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 2
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": [1, 2, 5, 10]
            }
          }
        },
        "responses": {
          "200": {
            "description": "分配成功",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": null }
              }
            }
          }
        }
      }
    },
    "/role/{id}/menu-ids": {
      "get": {
        "tags": ["角色管理"],
        "summary": "获取角色已分配的菜单ID",
        "description": "查询角色已分配的菜单权限ID列表",
        "operationId": "getRoleMenuIds",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" },
            "example": 2
          }
        ],
        "responses": {
          "200": {
            "description": "成功返回菜单ID列表",
            "content": {
              "application/json": {
                "example": { "code": 200, "message": "success", "data": [1, 2, 5, 10] }
              }
            }
          }
        }
      }
    },
    "/menu/tree": {
      "get": {
