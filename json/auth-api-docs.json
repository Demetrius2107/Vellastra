                        {
                          "id": 5, "menuName": "角色管理", "menuType": 2, "parentId": 1, "path": "/system/role", "component": "system/role/index", "perms": null, "icon": "team", "sortOrder": 2, "visible": 1, "status": 1, "createTime": "2026-07-18T10:00:00",
                          "children": [
                            { "id": 6, "menuName": "新增角色", "menuType": 3, "parentId": 5, "path": null, "component": null, "perms": "role:create", "icon": null, "sortOrder": 1, "visible": 1, "status": 1, "createTime": "2026-07-18T10:00:00" }
